# Отримай від @BotFather в Telegram
BOT_TOKEN=your_bot_token_here

# URL твого сервера після деплою (Railway дасть автоматично)
# Формат: https://hfaly-production.up.railway.app
APP_URL=https://your-app.up.railway.app

# Порт (Railway підставляє автоматично)
PORT=3000

# ─── Блокчейн TON (NFT-карти) ─────────────────────────────────────────
# Мережа: testnet (для розробки) або mainnet
TON_NETWORK=testnet

# Адреса розгорнутої NFT-колекції (див. README). Порожня → мінт вимкнено,
# гра працює як звичайно, NFT-секція показує "Скоро".
NFT_COLLECTION_ADDRESS=

# Ключ tonapi.io / toncenter (опційно, для вищих лімітів і server mint)
TONAPI_KEY=

# Мнемоніка (24 слова) кошелька-мінтера для СЕРВЕРНОГО мінту (нагороди/івенти).
# Порожня → серверний мінт вимкнено (гравці все одно можуть мінтити самі).
MINTER_MNEMONIC=

# Вимагати криптографічний TON Connect proof при прив'язці гаманця
# (true у проді, false зручно в dev)
TON_REQUIRE_PROOF=false

# Ціна мінту NFT для гравця, у TON
NFT_MINT_PRICE_TON=1

# Вимагати підписаний Telegram initData (захист від підміни tgId).
# Порожньо = авто: увімкнено в production якщо є BOT_TOKEN, вимкнено в dev.
# REQUIRE_TG_AUTH=true

# Ім'я бота без @ (для deep-link запрошень t.me/<бот>?startapp=<код>).
# Якщо порожньо — візьметься автоматично через getMe() при старті бота.
BOT_USERNAME=

# Ключ адмін-панелі (/admin). Без нього в production панель вимкнена.
ADMIN_KEY=

# Посилання на Telegram-групу гри (кнопка «Спільнота» на головній)
GROUP_LINK=
